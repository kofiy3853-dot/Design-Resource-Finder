<%- include('partials/header-app') %>
<%- include('partials/dashboard-layout') %>

<div class="dash-page-header" style="display:flex;flex-wrap:wrap;justify-content:space-between;align-items:flex-start;gap:16px">
  <div>
    <h1>Saved Items</h1>
    <p>Your bookmarked analyses</p>
  </div>
  <a href="/history" class="dash-btn-secondary">
    <span class="material-symbols-outlined" style="font-size:18px">history</span> View all history
  </a>
</div>

<% if (items && items.length > 0) { %>
<div style="display:flex;flex-direction:column;gap:12px">
  <% items.forEach(function(item) { %>
  <a href="/analysis/<%= item.analysis_id %>" class="dash-card" style="display:flex;align-items:center;gap:12px;text-decoration:none;cursor:pointer" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">
    <div style="width:48px;height:48px;border-radius:12px;background:rgba(124,58,237,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0">
      <span class="material-symbols-outlined" style="color:var(--primary)"><%= item.status === 'completed' ? 'check_circle' : 'progress_activity' %></span>
    </div>
    <div style="flex:1;min-width:0">
      <p style="font-size:14px;font-weight:600;color:var(--on-surface);white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= item.analysis_title || 'Untitled' %></p>
      <p style="font-size:12px;color:var(--text-muted)">Saved · <%= new Date(item.created_at).toLocaleDateString() %></p>
    </div>
    <span class="material-symbols-outlined" style="color:var(--text-muted);font-size:20px">chevron_right</span>
  </a>
  <% }) %>
</div>
<% } else { %>
<div class="dash-card" style="text-align:center;padding:80px 20px">
  <span class="material-symbols-outlined" style="font-size:56px;color:var(--text-muted);opacity:0.3;margin-bottom:16px;display:block">bookmark</span>
  <h3 style="font-size:18px;font-weight:600;color:var(--on-surface);margin-bottom:8px">No saved items yet</h3>
  <p style="font-size:14px;color:var(--text-secondary)">Bookmark analyses to quickly find them later.</p>
</div>
<% } %>

<%- include('partials/dashboard-footer') %>
