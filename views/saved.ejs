<%- include('partials/header') %>
<div class="pt-24 pb-xl max-w-container-max mx-auto px-md">
<div class="flex justify-between items-center mb-xl">
<div>
<h1 class="font-headline-lg text-headline-lg">Saved Items</h1>
<p class="font-body-md text-body-md text-on-surface-variant">Your bookmarked analyses</p>
</div>
<a href="/history" class="text-primary hover:underline font-body-md">View all history</a>
</div>
<% if (items && items.length > 0) { %>
<div class="space-y-md">
<% items.forEach(item => { %>
<a href="/analysis/<%= item.analysis_id %>" class="glass-card p-md rounded-xl flex items-center gap-md hover:border-primary/30 transition-all block">
<div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
<span class="material-symbols-outlined text-primary"><%= item.status === 'completed' ? 'check_circle' : 'progress_activity' %></span>
</div>
<div class="flex-1 min-w-0">
<p class="font-body-md text-body-md text-on-surface truncate"><%= item.analysis_title || 'Untitled' %></p>
<p class="font-label-sm text-label-sm text-on-surface-variant">Saved · <%= new Date(item.created_at).toLocaleDateString() %></p>
</div>
<span class="material-symbols-outlined text-on-surface-variant">chevron_right</span>
</a>
<% }) %>
</div>
<% } else { %>
<div class="glass-card p-xl rounded-xl text-center">
<span class="material-symbols-outlined text-5xl text-on-surface-variant/30 mb-md" style="font-variation-settings: 'FILL' 1;">bookmark</span>
<p class="font-body-lg text-body-lg text-on-surface-variant mb-md">No saved items yet</p>
<p class="font-body-md text-body-md text-on-surface-variant">Bookmark analyses to quickly find them later.</p>
</div>
<% } %>
</div>
<%- include('partials/footer') %>
