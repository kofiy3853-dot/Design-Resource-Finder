<%- include('partials/header-app') %>
<%- include('partials/dashboard-layout') %>

<div class="dash-page-header">
  <h1>Search</h1>
  <p>Search your analyses by font, color, style, or keyword</p>
</div>

<!-- Search Form -->
<form method="GET" action="/search" style="margin-bottom:24px">
  <div style="display:flex;gap:12px">
    <div style="flex:1;position:relative">
      <span class="material-symbols-outlined" style="position:absolute;left:14px;top:50%;transform:translateY(-50%);font-size:18px;color:var(--text-muted)">search</span>
      <input name="q" value="<%= query %>" placeholder="Search by font, color, style, or keyword..." style="width:100%;padding:12px 14px 12px 42px;border-radius:var(--radius-sm);border:1px solid var(--nav-border);background:var(--card-bg);font-size:14px;color:var(--on-surface);outline:none;font-family:inherit"/>
    </div>
    <button type="submit" class="dash-btn-primary" style="width:auto;padding:12px 24px">
      <span class="material-symbols-outlined">search</span> Search
    </button>
  </div>
</form>

<% if (query) { %>
<p style="font-size:13px;color:var(--text-muted);margin-bottom:16px"><%= results.length %> result(s) for "<%= query %>"</p>

<% if (results.length > 0) { %>
<div style="display:flex;flex-direction:column;gap:12px">
  <% results.forEach(function(a) { %>
  <a href="/analysis/<%= a.id %>" class="dash-card" style="display:flex;align-items:center;gap:12px;text-decoration:none;cursor:pointer" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">
    <div style="flex:1;min-width:0">
      <p style="font-size:14px;font-weight:600;color:var(--on-surface);white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= a.title || 'Untitled' %></p>
      <p style="font-size:12px;color:var(--text-muted)"><%= new Date(a.created_at).toLocaleDateString() %></p>
    </div>
    <span style="padding:4px 12px;border-radius:12px;font-size:11px;font-weight:700;background:<%= a.status === 'completed' ? 'rgba(124,58,237,0.2)' : 'rgba(107,114,128,0.2)' %>;color:<%= a.status === 'completed' ? 'var(--primary)' : 'var(--text-muted)' %>"><%= a.status %></span>
  </a>
  <% }) %>
</div>
<% } else { %>
<div class="dash-card" style="text-align:center;padding:80px 20px">
  <span class="material-symbols-outlined" style="font-size:56px;color:var(--text-muted);opacity:0.3;margin-bottom:16px;display:block">search_off</span>
  <h3 style="font-size:18px;font-weight:600;color:var(--on-surface);margin-bottom:8px">No results found</h3>
  <p style="font-size:14px;color:var(--text-secondary)">Try different keywords.</p>
</div>
<% } %>
<% } %>

<%- include('partials/dashboard-footer') %>
