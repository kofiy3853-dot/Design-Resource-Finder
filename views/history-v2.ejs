<%- include('partials/header-app') %>
<div class="dash-page">
  <div class="dash-sidebar-overlay" id="sidebarOverlay"></div>

  <div class="dash-layout">
    <aside class="dash-sidebar" id="sidebar">
      <div class="dash-sidebar-header">
        <div class="dash-sidebar-logo"><span class="material-symbols-outlined">auto_awesome</span></div>
        <div class="dash-sidebar-brand">
          <h3>Design Resource Finder</h3>
          <p>Dashboard</p>
        </div>
      </div>
      <nav class="dash-sidebar-nav">
        <ul>
          <li class="dash-nav-label">Main</li>
          <li><a class="dash-nav-item" href="/dashboard"><span class="material-symbols-outlined">dashboard</span> Dashboard</a></li>
          <li><a class="dash-nav-item" href="/upload"><span class="material-symbols-outlined">upload_file</span> Upload Design</a></li>
          <li><a class="dash-nav-item active" href="/history"><span class="material-symbols-outlined">history</span> History</a></li>
          <li><a class="dash-nav-item" href="/projects"><span class="material-symbols-outlined">folder</span> Projects</a></li>
          <li><a class="dash-nav-item" href="/favorites"><span class="material-symbols-outlined">favorite</span> Favorites</a></li>
          <li><a class="dash-nav-item" href="/bg-generator"><span class="material-symbols-outlined">auto_fix_high</span> AI Background Generator</a></li>
          <li class="dash-nav-label">Resources</li>
          <li><a class="dash-nav-item" href="/resources"><span class="material-symbols-outlined">grid_view</span> Resources</a></li>
          <li><a class="dash-nav-item" href="/pricing"><span class="material-symbols-outlined">sell</span> Pricing</a></li>
          <li><a class="dash-nav-item" href="/settings"><span class="material-symbols-outlined">settings</span> Settings</a></li>
          <li><a class="dash-nav-item" href="/help"><span class="material-symbols-outlined">help</span> Help & Support</a></li>
        </ul>
      </nav>
      <div class="dash-sidebar-footer">
        <div class="dash-upgrade-card">
          <h4>Upgrade to Pro</h4>
          <p>Unlock unlimited analyses</p>
          <a href="/pricing" class="dash-upgrade-btn dash-ripple">Upgrade Now</a>
        </div>
        <div class="dash-user-card">
          <div class="dash-avatar"><%= user?.name ? user.name.charAt(0).toUpperCase() : 'U' %></div>
          <div class="dash-user-info">
            <h4><%= user?.name || 'User' %></h4>
            <p><%= user?.email || 'user@example.com' %></p>
          </div>
          <span class="material-symbols-outlined dash-user-toggle" id="userMenuToggle">expand_more</span>
          <div class="dash-user-dropdown" id="userDropdown">
            <a href="/profile">Profile</a>
            <a href="/settings">Settings</a>
            <a href="/achievements">Achievements</a>
            <a href="/auth/logout" class="dash-logout">Sign Out</a>
          </div>
        </div>
      </div>
    </aside>

    <main class="dash-main">
      <div class="dash-content">
        <div class="dash-page-header">
          <a href="/dashboard" class="flex items-center gap-xs font-body-md"><span class="material-symbols-outlined">arrow_back</span> Back to Dashboard</a>
          <h1>Analysis History</h1>
          <p>Browse and manage your previously analyzed design resources.</p>
        </div>

        <!-- Search + Filter -->
        <div style="display:flex;flex-wrap:wrap;gap:12px;justify-content:space-between;align-items:center;margin-bottom:20px">
          <div class="search-wrapper" style="flex:1;max-width:600px">
            <div class="search-input-wrap">
              <span class="material-symbols-outlined">search</span>
              <input type="text" id="searchInput" placeholder="Search by design name, font, or color..." aria-label="Search history"/>
            </div>
            <button class="filter-btn" id="filterBtn">
              <span class="material-symbols-outlined" style="font-size:18px">tune</span> Filter
            </button>
          </div>
        </div>

        <!-- Category Pills -->
        <div class="category-pills" id="categoryPills" role="tablist">
          <button class="pill active" data-category="all">All History</button>
          <button class="pill" data-category="banners">Ad Banners</button>
          <button class="pill" data-category="ui">UI Components</button>
          <button class="pill" data-category="logos">Logos</button>
          <button class="pill" data-category="illustrations">Illustrations</button>
          <button class="pill" data-category="web">Web Layouts</button>
        </div>

        <!-- History Grid -->
        <div style="margin-top:24px">
          <div class="history-grid" id="historyGrid"></div>

          <!-- Empty State -->
          <div class="empty-state" id="emptyState" style="display:none">
            <span class="material-symbols-outlined">search_off</span>
            <h3>No results found</h3>
            <p>Try adjusting your search or filter to find what you're looking for.</p>
          </div>
        </div>

        <!-- Pagination -->
        <div class="pagination-section" id="paginationSection">
          <p id="showingText">No analyses yet</p>
          <button class="load-more-btn" id="loadMoreBtn">
            <span class="material-symbols-outlined" style="font-size:18px">expand_more</span> Load More History
          </button>
        </div>
      </div>
    </main>
  </div>

  <div class="dash-toast-container" id="toastContainer"></div>
</div>

<style>
  .history-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:20px; }
  @media(max-width:1024px){.history-grid{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:768px){.history-grid{grid-template-columns:1fr}}

  .history-card {
    background:var(--card-bg);border:1px solid var(--border);border-radius:var(--radius-lg);
    overflow:hidden;transition:var(--transition);cursor:pointer;position:relative;
  }
  .history-card:hover { transform:translateY(-6px); box-shadow:var(--shadow-xl); }

  .history-card-image {
    position:relative;aspect-ratio:16/9;background:var(--bg);
    display:flex;align-items:center;justify-content:center;overflow:hidden;
  }
  .history-card-image .placeholder-icon { font-size:48px;color:var(--text-muted);opacity:0.3; }

  .history-card-badge {
    position:absolute;top:12px;right:12px;
    display:flex;align-items:center;gap:4px;
    background:rgba(16,185,129,0.9);color:#fff;
    padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600;
    backdrop-filter:blur(8px);
  }
  .history-card-badge .material-symbols-outlined { font-size:14px; }

  .history-card-body { padding:16px; }
  .history-card-body h3 { font-size:15px;font-weight:600;color:var(--text-primary);margin-bottom:4px; }
  .history-card-body .date { font-size:12px;color:var(--text-muted);margin-bottom:12px; }

  .history-color-strip {
    display:flex;gap:4px;align-items:center;margin-bottom:12px;
  }
  .history-color-strip .dot {
    width:20px;height:20px;border-radius:50%;border:2px solid var(--border);flex-shrink:0;
  }
  .history-color-strip .more {
    width:20px;height:20px;border-radius:50%;background:var(--bg);
    display:flex;align-items:center;justify-content:center;
    font-size:9px;font-weight:600;color:var(--text-muted);flex-shrink:0;
  }

  .history-card-stats {
    display:flex;gap:16px;padding-top:12px;border-top:1px solid var(--border);
  }
  .history-card-stats .stat { display:flex;align-items:center;gap:4px;font-size:12px;color:var(--text-secondary); }
  .history-card-stats .stat .material-symbols-outlined { font-size:16px;color:var(--primary); }

  .history-card-delete {
    position:absolute;top:12px;left:12px;width:28px;height:28px;border-radius:50%;
    background:rgba(0,0,0,0.4);color:#fff;display:flex;align-items:center;justify-content:center;
    font-size:16px;opacity:0;transition:var(--transition);backdrop-filter:blur(4px);
  }
  .history-card:hover .history-card-delete { opacity:1; }
  .history-card-delete:hover { background:rgba(239,68,68,0.8); }

  .search-wrapper {
    display:flex;gap:12px;align-items:center;
  }
  .search-input-wrap {
    flex:1;position:relative;max-width:400px;
  }
  .search-input-wrap .material-symbols-outlined {
    position:absolute;left:14px;top:50%;transform:translateY(-50%);font-size:18px;color:var(--text-muted);
  }
  .search-input-wrap input {
    width:100%;padding:10px 14px 10px 42px;border-radius:var(--radius-sm);
    border:1px solid var(--border);background:var(--card-bg);font-size:14px;color:var(--text-primary);
    outline:none;transition:var(--transition);font-family:inherit;
  }
  .search-input-wrap input:focus { border-color:var(--primary);box-shadow:0 0 0 3px rgba(124,58,237,0.1); }
  .search-input-wrap input::placeholder { color:var(--text-muted); }

  .filter-btn {
    display:flex;align-items:center;gap:6px;padding:10px 16px;border-radius:var(--radius-sm);
    border:1px solid var(--border);background:var(--card-bg);font-size:14px;font-weight:500;
    color:var(--text-secondary);transition:var(--transition);cursor:pointer;font-family:inherit;
  }
  .filter-btn:hover { border-color:var(--primary);color:var(--primary); }

  .category-pills {
    display:flex;gap:8px;overflow-x:auto;padding:4px 0;scrollbar-width:none;
    -webkit-overflow-scrolling:touch;
  }
  .category-pills::-webkit-scrollbar { display:none; }

  .pill {
    white-space:nowrap;padding:8px 18px;border-radius:20px;font-size:13px;font-weight:500;
    transition:var(--transition);cursor:pointer;border:1px solid var(--border);
    background:var(--card-bg);color:var(--text-secondary);flex-shrink:0;font-family:inherit;
  }
  .pill:hover { border-color:var(--primary);color:var(--primary); }
  .pill.active { background:var(--primary);color:#fff;border-color:var(--primary); }

  .fab {
    position:fixed;bottom:24px;right:24px;width:56px;height:56px;border-radius:50%;
    background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;
    box-shadow:0 4px 20px rgba(124,58,237,0.4);transition:var(--transition);cursor:pointer;
    z-index:100;border:none;font-size:28px;
  }
  .fab:hover { transform:scale(1.1);box-shadow:0 8px 32px rgba(124,58,237,0.5); }
  .fab:active { transform:scale(0.95); }

  .pagination-section {
    text-align:center;padding:40px 0 20px;
  }
  .pagination-section p { font-size:13px;color:var(--text-muted);margin-bottom:12px; }
  .load-more-btn {
    display:inline-flex;align-items:center;gap:8px;
    padding:12px 28px;border-radius:var(--radius-sm);background:var(--primary);color:#fff;
    font-size:14px;font-weight:600;border:none;cursor:pointer;transition:var(--transition);
    font-family:inherit;
  }
  .load-more-btn:hover { background:var(--primary-hover);transform:translateY(-2px);box-shadow:0 4px 16px rgba(124,58,237,0.3); }

  .empty-state { text-align:center;padding:80px 20px; }
  .empty-state .material-symbols-outlined { font-size:64px;color:var(--text-muted);opacity:0.3;margin-bottom:16px; }
  .empty-state h3 { font-size:18px;font-weight:600;color:var(--text-primary);margin-bottom:8px; }
  .empty-state p { font-size:14px;color:var(--text-secondary); }
</style>

<script>
  window.historyAnalyses = <%- JSON.stringify(analyses || []) %>;
</script>
<script src="/js/dashboard-v2.js"></script>
<script src="/js/history-v2.js"></script>
<%- include('partials/footer') %>
