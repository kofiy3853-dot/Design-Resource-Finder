<%- include('partials/header-app') %>
<%- include('partials/dashboard-layout') %>

<div class="dash-page-header">
  <h1>Achievements</h1>
  <p>Track your progress and unlock badges as you analyze more designs</p>
</div>

<!-- Stats Overview -->
<div class="dash-stats" style="margin-bottom:24px">
  <div class="dash-stat-card">
    <div class="dash-stat-icon"><span class="material-symbols-outlined">trending_up</span></div>
    <div class="dash-stat-number"><%= stats.total_analyses || 0 %></div>
    <div class="dash-stat-label">Total Analyses</div>
  </div>
  <div class="dash-stat-card">
    <div class="dash-stat-icon" style="background:rgba(197,189,255,0.1);color:var(--secondary)"><span class="material-symbols-outlined">local_fire_department</span></div>
    <div class="dash-stat-number"><%= streak.current_streak || 0 %></div>
    <div class="dash-stat-label">Current Streak</div>
    <div class="dash-stat-sub">Best: <%= streak.longest_streak || 0 %></div>
  </div>
  <div class="dash-stat-card">
    <div class="dash-stat-icon" style="background:rgba(195,199,205,0.1);color:var(--tertiary)"><span class="material-symbols-outlined">bookmark</span></div>
    <div class="dash-stat-number"><%= stats.total_favorites || 0 %></div>
    <div class="dash-stat-label">Saved Items</div>
  </div>
  <div class="dash-stat-card">
    <div class="dash-stat-icon"><span class="material-symbols-outlined">stars</span></div>
    <div class="dash-stat-number"><%= Math.round(stats.avg_confidence_score || 0) %>%</div>
    <div class="dash-stat-label">Avg. Confidence</div>
  </div>
</div>

<!-- Achievements Grid -->
<div class="dash-card">
  <h3 style="font-size:16px;font-weight:600;color:var(--on-surface);margin-bottom:16px">Badges Earned</h3>

  <% if (achievements && achievements.length > 0) { %>
  <div class="history-grid">
    <% achievements.forEach(function(a) { %>
    <div class="resource-card" style="display:flex;align-items:flex-start;gap:12px">
      <div style="width:48px;height:48px;border-radius:12px;background:rgba(124,58,237,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0">
        <span class="material-symbols-outlined" style="color:var(--primary);font-size:24px"><%= a.icon_name %></span>
      </div>
      <div style="flex:1;min-width:0">
        <p style="font-size:14px;font-weight:600;color:var(--on-surface)"><%= a.achievement_name %></p>
        <p style="font-size:13px;color:var(--text-secondary);margin-top:4px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden"><%= a.description %></p>
        <p style="font-size:11px;color:var(--text-muted);margin-top:8px">Earned <%= new Date(a.earned_at).toLocaleDateString() %></p>
      </div>
    </div>
    <% }) %>
  </div>
  <% } else { %>
  <div style="text-align:center;padding:40px 20px">
    <span class="material-symbols-outlined" style="font-size:48px;color:var(--text-muted);opacity:0.3;margin-bottom:12px;display:block">emoji_events</span>
    <p style="font-size:14px;color:var(--text-secondary)">Start analyzing designs to earn badges!</p>
  </div>
  <% } %>
</div>

<%- include('partials/dashboard-footer') %>
