<%- include('partials/header') %>
<div class="pt-24 pb-xl">
  <div class="max-w-7xl mx-auto px-md">
    <!-- Header -->
    <div class="text-center mb-xl">
      <h1 class="font-headline-lg text-headline-lg text-on-surface mb-sm">Community Gallery</h1>
      <p class="font-body-md text-body-md text-on-surface-variant max-w-2xl mx-auto">Explore beautifully analyzed designs from our community. See how different styles are deconstructed and categorized.</p>
    </div>

    <!-- Featured Analyses Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-lg">
      <!-- Card 1 -->
      <div class="glass-card rounded-2xl overflow-hidden hover:border-primary/30 transition-all group">
        <div class="relative h-64 bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center overflow-hidden">
          <div class="absolute inset-0 opacity-10">
            <div class="absolute w-96 h-96 bg-primary rounded-full -top-32 -right-32 group-hover:scale-110 transition-transform duration-500"></div>
            <div class="absolute w-96 h-96 bg-secondary rounded-full -bottom-32 -left-32 group-hover:scale-110 transition-transform duration-500"></div>
          </div>
          <span class="material-symbols-outlined text-6xl text-primary/40 relative z-10">palette</span>
        </div>
        <div class="p-lg">
          <h3 class="font-headline-sm text-headline-sm text-on-surface mb-sm">Modern Minimalist Design</h3>
          <p class="font-body-sm text-body-sm text-on-surface-variant mb-md line-clamp-2">A clean, contemporary design showcasing the power of negative space and bold typography.</p>
          <div class="flex gap-sm mb-md">
            <span class="px-sm py-1 rounded-full bg-primary/20 text-primary font-label-sm text-label-sm text-xs">Minimalist</span>
            <span class="px-sm py-1 rounded-full bg-secondary/20 text-secondary font-label-sm text-label-sm text-xs">Modern</span>
          </div>
          <div class="flex items-center gap-sm pt-md border-t border-white/5">
            <span class="text-2xl font-bold text-primary">92%</span>
            <span class="font-body-sm text-body-sm text-on-surface-variant">Confidence Score</span>
          </div>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="glass-card rounded-2xl overflow-hidden hover:border-primary/30 transition-all group">
        <div class="relative h-64 bg-gradient-to-br from-tertiary/20 to-primary/20 flex items-center justify-center overflow-hidden">
          <div class="absolute inset-0 opacity-10">
            <div class="absolute w-96 h-96 bg-tertiary rounded-full -top-32 -right-32 group-hover:scale-110 transition-transform duration-500"></div>
            <div class="absolute w-96 h-96 bg-primary rounded-full -bottom-32 -left-32 group-hover:scale-110 transition-transform duration-500"></div>
          </div>
          <span class="material-symbols-outlined text-6xl text-tertiary/40 relative z-10">text_fields</span>
        </div>
        <div class="p-lg">
          <h3 class="font-headline-sm text-headline-sm text-on-surface mb-sm">Bold Typography Focus</h3>
          <p class="font-body-sm text-body-sm text-on-surface-variant mb-md line-clamp-2">Creative layout using expressive typefaces with strategic color blocking for impact.</p>
          <div class="flex gap-sm mb-md">
            <span class="px-sm py-1 rounded-full bg-tertiary/20 text-tertiary font-label-sm text-label-sm text-xs">Typography</span>
            <span class="px-sm py-1 rounded-full bg-primary/20 text-primary font-label-sm text-label-sm text-xs">Bold</span>
          </div>
          <div class="flex items-center gap-sm pt-md border-t border-white/5">
            <span class="text-2xl font-bold text-secondary">88%</span>
            <span class="font-body-sm text-body-sm text-on-surface-variant">Confidence Score</span>
          </div>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="glass-card rounded-2xl overflow-hidden hover:border-primary/30 transition-all group">
        <div class="relative h-64 bg-gradient-to-br from-secondary/20 to-tertiary/20 flex items-center justify-center overflow-hidden">
          <div class="absolute inset-0 opacity-10">
            <div class="absolute w-96 h-96 bg-secondary rounded-full -top-32 -right-32 group-hover:scale-110 transition-transform duration-500"></div>
            <div class="absolute w-96 h-96 bg-tertiary rounded-full -bottom-32 -left-32 group-hover:scale-110 transition-transform duration-500"></div>
          </div>
          <span class="material-symbols-outlined text-6xl text-secondary/40 relative z-10">layout_grid_view</span>
        </div>
        <div class="p-lg">
          <h3 class="font-headline-sm text-headline-sm text-on-surface mb-sm">Grid-Based Layout</h3>
          <p class="font-body-sm text-body-sm text-on-surface-variant mb-md line-clamp-2">Structured composition using a strict grid system with harmonious color relationships.</p>
          <div class="flex gap-sm mb-md">
            <span class="px-sm py-1 rounded-full bg-secondary/20 text-secondary font-label-sm text-label-sm text-xs">Layout</span>
            <span class="px-sm py-1 rounded-full bg-tertiary/20 text-tertiary font-label-sm text-label-sm text-xs">Structured</span>
          </div>
          <div class="flex items-center gap-sm pt-md border-t border-white/5">
            <span class="text-2xl font-bold text-primary">95%</span>
            <span class="font-body-sm text-body-sm text-on-surface-variant">Confidence Score</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Featured Resources -->
    <div class="mt-xl pt-xl border-t border-white/5">
      <h2 class="font-headline-sm text-headline-sm text-on-surface mb-lg">Recommended Resources</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-lg">
        <div class="glass-card p-lg rounded-xl flex items-start gap-md">
          <div class="w-12 h-12 rounded-lg bg-primary/20 flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-primary text-2xl">school</span>
          </div>
          <div class="flex-1">
            <h3 class="font-body-md text-body-md text-on-surface font-bold mb-xs">Design Fundamentals Course</h3>
            <p class="font-body-sm text-body-sm text-on-surface-variant mb-md">Master the basics of color theory, typography, and layout principles.</p>
            <a href="#" class="text-primary font-body-sm font-bold hover:text-secondary transition-colors inline-flex items-center gap-xs">
              Learn more <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
            </a>
          </div>
        </div>

        <div class="glass-card p-lg rounded-xl flex items-start gap-md">
          <div class="w-12 h-12 rounded-lg bg-secondary/20 flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-secondary text-2xl">palette</span>
          </div>
          <div class="flex-1">
            <h3 class="font-body-md text-body-md text-on-surface font-bold mb-xs">Color Theory Guide</h3>
            <p class="font-body-sm text-body-sm text-on-surface-variant mb-md">Understanding color harmonies, contrast, and psychological impact in design.</p>
            <a href="#" class="text-primary font-body-sm font-bold hover:text-secondary transition-colors inline-flex items-center gap-xs">
              Learn more <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
