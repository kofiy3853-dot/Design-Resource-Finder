<%- include('partials/header') %>
<div class="pt-24 pb-xl max-w-container-max mx-auto px-md">
<h1 class="font-headline-lg text-headline-lg mb-xl">My Reports</h1>
<% if (reports && reports.length > 0) { %>
<div class="space-y-md">
<% reports.forEach(r => { %>
<div class="glass-card p-md rounded-xl flex items-center gap-md hover:border-primary/30 transition-all">
<div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
<span class="material-symbols-outlined text-primary">description</span>
</div>
<div class="flex-1 min-w-0">
<p class="font-body-md text-body-md text-on-surface truncate"><%= r.title || r.analysis_title %></p>
<p class="font-label-sm text-label-sm text-on-surface-variant"><%= r.format.toUpperCase() %> · <%= new Date(r.created_at).toLocaleDateString() %></p>
</div>
<div class="flex gap-xs">
<a href="<%= r.file_path %>" class="px-sm py-2 bg-primary/10 text-primary rounded-lg hover:bg-primary/20 transition-all"><span class="material-symbols-outlined">download</span></a>
</div>
</div>
<% }) %>
</div>
<% } else { %>
<div class="glass-card p-xl rounded-xl text-center">
<span class="material-symbols-outlined text-5xl text-on-surface-variant/30 mb-md" style="font-variation-settings: 'FILL' 1;">summarize</span>
<p class="font-body-lg text-body-lg text-on-surface-variant mb-md">No reports yet</p>
<p class="font-body-md text-body-md text-on-surface-variant">Analyze a design and save a report to see it here.</p>
</div>
<% } %>
</div>
<%- include('partials/footer') %>
