<%- include('partials/header-app') %>
<%- include('partials/dashboard-layout') %>

<div class="dash-page-header">
  <h1>My Reports</h1>
  <p>Download and manage your analysis reports</p>
</div>

<% if (reports && reports.length > 0) { %>
<div style="display:flex;flex-direction:column;gap:12px">
  <% reports.forEach(function(r) { %>
  <div class="dash-card" style="display:flex;align-items:center;gap:12px">
    <div style="width:48px;height:48px;border-radius:12px;background:rgba(124,58,237,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0">
      <span class="material-symbols-outlined" style="color:var(--primary)">description</span>
    </div>
    <div style="flex:1;min-width:0">
      <p style="font-size:14px;font-weight:600;color:var(--on-surface);white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= r.title || r.analysis_title %></p>
      <p style="font-size:12px;color:var(--text-muted)"><%= r.format.toUpperCase() %> · <%= new Date(r.created_at).toLocaleDateString() %></p>
    </div>
    <a href="<%= r.file_path %>" class="dash-btn-secondary" style="padding:8px 12px">
      <span class="material-symbols-outlined" style="font-size:18px">download</span>
    </a>
  </div>
  <% }) %>
</div>
<% } else { %>
<div class="dash-card" style="text-align:center;padding:80px 20px">
  <span class="material-symbols-outlined" style="font-size:56px;color:var(--text-muted);opacity:0.3;margin-bottom:16px;display:block">summarize</span>
  <h3 style="font-size:18px;font-weight:600;color:var(--on-surface);margin-bottom:8px">No reports yet</h3>
  <p style="font-size:14px;color:var(--text-secondary)">Analyze a design and save a report to see it here.</p>
</div>
<% } %>

<%- include('partials/dashboard-footer') %>
