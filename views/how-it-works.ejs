<%- include('partials/header') %>
<style>
.process-step { position: relative; }
.process-step::before { content: ''; position: absolute; top: 48px; left: 24px; width: 2px; height: calc(100% + 16px); background: linear-gradient(to bottom, rgba(179,197,255,0.3), transparent); }
.process-step:last-child::before { display: none; }
.flow-arrow { animation: flowDown 2s ease-in-out infinite; }
@keyframes flowDown { 0%,100% { transform: translateY(0); opacity: 0.5; } 50% { transform: translateY(8px); opacity: 1; } }
.stat-card { transition: all 0.3s ease-out; }
.stat-card:hover { transform: translateY(-4px); }
.faq-q { cursor: pointer; transition: all 0.2s; }
.faq-q:hover { background: rgba(255,255,255,0.03); }
.faq-a { max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out; }
.faq-a.open { max-height: 200px; }
</style>

<section class="relative min-h-[80vh] flex items-center pt-24 overflow-hidden">
