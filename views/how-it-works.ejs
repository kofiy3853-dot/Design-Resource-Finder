<div class="relative z-10 max-w-container-max mx-auto px-md w-full">
<div class="grid grid-cols-1 lg:grid-cols-2 gap-xl items-center">
<div class="reveal">
<div class="inline-flex items-center gap-xs px-sm py-xs bg-secondary-container/20 border border-secondary-container/30 rounded-full mb-md">
