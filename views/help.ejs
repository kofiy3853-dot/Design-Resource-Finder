<%- include('partials/header') %>
<main class="pt-24 pb-xl">
  <div class="max-w-3xl mx-auto px-md">
    <div class="mb-xl text-center">
      <h1 class="font-headline-lg text-headline-lg mb-sm">Help & Support</h1>
      <p class="font-body-md text-body-md text-on-surface-variant">Find answers to common questions and get help</p>
    </div>

    <!-- Search -->
    <div class="glass-card rounded-2xl p-lg mb-xl">
      <div class="relative">
        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
        <input type="text" id="helpSearch" placeholder="Search help articles..." class="w-full pl-12 pr-4 py-3 rounded-xl border border-white/10 bg-surface-container-high text-on-surface font-body-md" />
      </div>
    </div>

    <!-- Categories -->
    <div class="space-y-lg">
      <% const categories = [
        { icon: 'auto_awesome', title: 'Getting Started', articles: [
          { title: 'How to upload your first design', url: '#' },
          { title: 'Understanding your analysis results', url: '#' },
          { title: 'Navigating the dashboard', url: '#' },
          { title: 'Exporting and sharing reports', url: '#' },
        ]},
        { icon: 'text_fields', title: 'Font Analysis', articles: [
          { title: 'How font detection works', url: '#' },
          { title: 'Improving font detection accuracy', url: '#' },
          { title: 'Finding similar fonts', url: '#' },
        ]},
        { icon: 'palette', title: 'Color Analysis', articles: [
          { title: 'Understanding color palettes', url: '#' },
          { title: 'Color accessibility and WCAG', url: '#' },
          { title: 'Exporting color formats', url: '#' },
        ]},
        { icon: 'shield', title: 'Accessibility', articles: [
          { title: 'WCAG contrast requirements', url: '#' },
          { title: 'Reading order and structure', url: '#' },
          { title: 'Fixing common accessibility issues', url: '#' },
        ]},
        { icon: 'school', title: 'AI Design Mentor', articles: [
          { title: 'How to read AI explanations', url: '#' },
          { title: 'Using improvement suggestions', url: '#' },
          { title: 'Recreation guides for tools', url: '#' },
        ]},
        { icon: 'settings', title: 'Account & Settings', articles: [
          { title: 'Managing your subscription', url: '#' },
          { title: 'Data privacy and deletion', url: '#' },
          { title: 'Notification preferences', url: '#' },
        ]},
      ]; %>
      
      <% categories.forEach(cat => { %>
        <details class="glass-card rounded-2xl group">
          <summary class="p-lg flex items-center gap-md cursor-pointer font-headline-sm text-headline-sm list-none">
            <span class="material-symbols-outlined text-primary text-[24px]"><%= cat.icon %></span>
            <span><%= cat.title %></span>
            <span class="material-symbols-outlined ml-auto text-on-surface-variant transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-lg pb-lg border-t border-white/5">
            <ul class="space-y-sm">
              <% cat.articles.forEach(article => { %>
                <li>
                  <a href="<%= article.url %>" class="flex items-center gap-sm p-sm rounded-xl text-on-surface-variant hover:text-primary hover:bg-white/5 transition-colors font-body-md">
                    <span class="material-symbols-outlined text-[18px]">help_outline</span>
                    <%= article.title %>
                  </a>
                </li>
              <% }) %>
            </ul>
          </div>
        </details>
      <% }) %>
    </div>

    <!-- Contact Support -->
    <div class="glass-card rounded-2xl p-xl mt-xl text-center">
      <h2 class="font-headline-sm text-headline-sm mb-sm">Still need help?</h2>
      <p class="font-body-md text-body-md text-on-surface-variant mb-lg max-w-md mx-auto">Can't find what you're looking for? Our support team is here to help.</p>
      <a href="mailto:support@designresourcefinder.com" class="inline-flex items-center gap-xs px-lg py-sm bg-primary text-on-primary rounded-xl font-bold">
        <span class="material-symbols-outlined">mail</span> Contact Support
      </a>
    </div>
  </div>
</main>
<%- include('partials/footer') %>