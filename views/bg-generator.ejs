<%- include('partials/header-app') %>
<%- include('partials/dashboard-layout') %>

<div class="dash-page-header">
  <h1>AI Background Generator</h1>
  <p>Generate unique backgrounds with AI</p>
</div>

<div class="dash-grid-2">
  <!-- Prompt Input -->
  <div>
    <div class="dash-card" style="margin-bottom:16px">
      <h3 style="font-size:16px;font-weight:600;color:var(--on-surface);margin-bottom:16px">Generate Background</h3>

      <div style="margin-bottom:16px">
        <label style="font-size:12px;color:var(--text-muted);display:block;margin-bottom:6px">Style</label>
        <select id="bgStyle" style="width:100%;padding:10px 12px;border-radius:var(--radius-sm);border:1px solid var(--nav-border);background:var(--card-bg);font-size:14px;color:var(--on-surface);font-family:inherit">
          <option value="abstract">Abstract</option>
          <option value="gradient">Gradient</option>
          <option value="mesh">Mesh Gradient</option>
          <option value="geometric">Geometric</option>
          <option value="fluid">Fluid/Organic</option>
          <option value="noise">Noise/Texture</option>
          <option value="light">Light Effects</option>
        </select>
      </div>

      <div style="margin-bottom:16px">
        <label style="font-size:12px;color:var(--text-muted);display:block;margin-bottom:6px">Color Theme</label>
        <select id="bgColors" style="width:100%;padding:10px 12px;border-radius:var(--radius-sm);border:1px solid var(--nav-border);background:var(--card-bg);font-size:14px;color:var(--on-surface);font-family:inherit">
          <option value="auto">Auto (AI chooses)</option>
          <option value="warm">Warm</option>
          <option value="cool">Cool</option>
          <option value="vibrant">Vibrant</option>
          <option value="monochrome">Monochrome</option>
          <option value="pastel">Pastel</option>
          <option value="dark">Dark Mode</option>
        </select>
      </div>

      <div style="margin-bottom:16px">
        <label style="font-size:12px;color:var(--text-muted);display:block;margin-bottom:6px">Custom Prompt (optional)</label>
        <textarea id="bgPrompt" rows="3" style="width:100%;padding:10px 12px;border-radius:var(--radius-sm);border:1px solid var(--nav-border);background:var(--card-bg);font-size:14px;color:var(--on-surface);font-family:inherit;resize:none" placeholder="e.g., sunset over mountains, subtle grain texture..."></textarea>
      </div>

      <button id="generateBg" class="dash-btn-primary dash-ripple">
        <span class="material-symbols-outlined">auto_awesome</span> Generate Background
      </button>
    </div>

    <!-- Generated Results -->
    <div class="dash-card">
      <h3 style="font-size:16px;font-weight:600;color:var(--on-surface);margin-bottom:16px">Your Generated Backgrounds</h3>
      <div id="generatedBgs" style="display:grid;grid-template-columns:repeat(2,1fr);gap:8px"></div>
    </div>
  </div>

  <!-- Preview Area -->
  <div>
    <div class="dash-card" style="overflow:hidden">
      <div id="previewArea" style="aspect-ratio:16/9;background:var(--surface-container-high);display:flex;align-items:center;justify-content:center;position:relative;border-radius:12px;overflow:hidden">
        <span class="material-symbols-outlined" style="font-size:56px;color:var(--text-muted);opacity:0.3">image</span>
        <div style="position:absolute;top:12px;right:12px;display:flex;gap:8px">
          <button id="downloadBg" style="width:32px;height:32px;border-radius:50%;background:rgba(0,0,0,0.5);color:#fff;display:flex;align-items:center;justify-content:center;border:none;cursor:pointer" title="Download">
            <span class="material-symbols-outlined" style="font-size:18px">download</span>
          </button>
          <button id="regenerateBg" style="width:32px;height:32px;border-radius:50%;background:rgba(0,0,0,0.5);color:#fff;display:flex;align-items:center;justify-content:center;border:none;cursor:pointer" title="Regenerate">
            <span class="material-symbols-outlined" style="font-size:18px">refresh</span>
          </button>
        </div>
      </div>
      <div style="padding:16px;border-top:1px solid var(--nav-border);display:flex;align-items:center;justify-content:space-between">
        <p style="font-size:13px;color:var(--text-secondary)">Preview Area</p>
        <div style="display:flex;gap:8px">
          <button id="copyPrompt" class="dash-btn-secondary" style="padding:6px 12px">Copy Prompt</button>
          <button id="saveBg" class="dash-btn-primary" style="width:auto;padding:6px 12px">Save to Favorites</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  'use strict';

  const generateBtn = document.getElementById('generateBg');
  const previewArea = document.getElementById('previewArea');
  const generatedBgs = document.getElementById('generatedBgs');
  const downloadBtn = document.getElementById('downloadBg');
  const regenerateBtn = document.getElementById('regenerateBg');
  const copyBtn = document.getElementById('copyPrompt');
  const saveBtn = document.getElementById('saveBg');
  const styleSelect = document.getElementById('bgStyle');
  const colorSelect = document.getElementById('bgColors');
  const promptInput = document.getElementById('bgPrompt');

  let currentPrompt = '';
  let currentImageUrl = '';
  let currentBgId = null;

  const styleTemplates = {
    abstract: 'abstract art, fluid shapes, organic forms, modern aesthetic',
    gradient: 'smooth color gradients, seamless transitions, elegant color flow',
    mesh: 'mesh gradient, blurred colorful blobs, soft transitions, depth',
    geometric: 'geometric patterns, clean lines, precise shapes, mathematical beauty',
    fluid: 'fluid simulation, liquid motion, organic flow, marbling effect',
    noise: 'film grain, subtle texture, organic noise, analog feel',
    light: 'light rays, lens flares, volumetric lighting, ethereal glow'
  };

  const colorTemplates = {
    warm: 'warm color palette, oranges, reds, yellows, golden tones',
    cool: 'cool color palette, blues, purples, teals, icy tones',
    vibrant: 'highly saturated colors, vivid, energetic, bold',
    monochrome: 'monochromatic, single hue variations, minimal',
    pastel: 'soft pastel colors, muted, gentle, dreamy',
    dark: 'dark mode, deep colors, low light, moody atmosphere'
  };

  function buildPrompt() {
    let prompt = styleTemplates[styleSelect.value] || styleTemplates.abstract;
    if (colorSelect.value !== 'auto') prompt += ', ' + colorTemplates[colorSelect.value];
    if (promptInput.value.trim()) prompt += ', ' + promptInput.value.trim();
    prompt += ', high quality, 4k, professional design';
    return prompt;
  }

  function showLoading() {
    generateBtn.disabled = true;
    generateBtn.innerHTML = '<span class="material-symbols-outlined" style="animation:spin 1s linear infinite">progress_activity</span> Generating...';
    previewArea.innerHTML = '<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%"><div style="width:48px;height:48px;border:3px solid var(--primary);border-top-color:transparent;border-radius:50%;animation:spin 1s linear infinite;margin-bottom:16px"></div><p style="font-size:14px;color:var(--text-secondary)">Generating background...</p></div>';
  }

  function hideLoading() {
    generateBtn.disabled = false;
    generateBtn.innerHTML = '<span class="material-symbols-outlined">auto_awesome</span> Generate Background';
  }

  function setPreviewImage(url, prompt) {
    currentImageUrl = url;
    currentPrompt = prompt;
    previewArea.innerHTML = '<img src="' + url + '" alt="Generated background" style="width:100%;height:100%;object-fit:cover"><div style="position:absolute;top:12px;right:12px;display:flex;gap:8px"><button id="downloadBg" style="width:32px;height:32px;border-radius:50%;background:rgba(0,0,0,0.5);color:#fff;display:flex;align-items:center;justify-content:center;border:none;cursor:pointer" title="Download"><span class="material-symbols-outlined" style="font-size:18px">download</span></button><button id="regenerateBg" style="width:32px;height:32px;border-radius:50%;background:rgba(0,0,0,0.5);color:#fff;display:flex;align-items:center;justify-content:center;border:none;cursor:pointer" title="Regenerate"><span class="material-symbols-outlined" style="font-size:18px">refresh</span></button></div>';
    document.getElementById('downloadBg').addEventListener('click', downloadImage);
    document.getElementById('regenerateBg').addEventListener('click', generateBackground);
  }

  function addToGallery(url, prompt) {
    const item = document.createElement('div');
    item.style.cssText = 'position:relative;aspect-ratio:1;border-radius:12px;overflow:hidden;cursor:pointer;transition:transform 0.2s';
    item.onmouseover = function() { this.style.transform = 'scale(1.05)'; };
    item.onmouseout = function() { this.style.transform = 'scale(1)'; };
    item.innerHTML = '<img src="' + url + '" alt="Generated" style="width:100%;height:100%;object-fit:cover">';
    item.addEventListener('click', function() { setPreviewImage(url, prompt); });
    generatedBgs.insertBefore(item, generatedBgs.firstChild);
  }

  async function generateBackground() {
    const prompt = buildPrompt();
    showLoading();
    try {
      const response = await fetch('/api/bg/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ style: styleSelect.value, color_theme: colorSelect.value, custom_prompt: promptInput.value.trim(), prompt: prompt })
      });
      const data = await response.json();
      if (!response.ok) throw new Error(data.error || 'Generation failed');
      currentBgId = data.background.id;
      setPreviewImage(data.background.url, prompt);
      addToGallery(data.background.url, prompt);
    } catch (err) {
      console.error(err);
      previewArea.innerHTML = '<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;text-align:center;padding:20px"><span class="material-symbols-outlined" style="font-size:48px;color:var(--error);margin-bottom:8px">error_outline</span><p style="font-size:14px;color:var(--text-secondary)">Failed to generate</p><p style="font-size:12px;color:var(--error);margin-top:4px">' + err.message + '</p></div>';
    } finally {
      hideLoading();
    }
  }

  function downloadImage() {
    if (!currentImageUrl) return;
    var a = document.createElement('a');
    a.href = currentImageUrl;
    a.download = 'bg-' + Date.now() + '.png';
    a.click();
  }

  function copyPrompt() {
    if (!currentPrompt) return;
    navigator.clipboard.writeText(currentPrompt);
  }

  async function saveBackground() {
    if (!currentBgId) return;
    try {
      await fetch('/api/bg/save', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ bg_id: currentBgId }) });
    } catch (err) { console.error(err); }
  }

  generateBtn.addEventListener('click', generateBackground);
  downloadBtn.addEventListener('click', downloadImage);
  regenerateBtn.addEventListener('click', generateBackground);
  copyBtn.addEventListener('click', copyPrompt);
  saveBtn.addEventListener('click', saveBackground);
  promptInput.addEventListener('keydown', function(e) { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); generateBackground(); } });
})();
</script>

<style>@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }</style>

<%- include('partials/dashboard-footer') %>
