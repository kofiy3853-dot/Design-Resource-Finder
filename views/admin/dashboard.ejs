<%- include('../partials/header') %>
<div class="pt-24 pb-xl max-w-container-max mx-auto px-md">
  <!-- Header -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-xl gap-md">
    <div>
      <h1 class="font-headline-lg text-headline-lg mb-xs">Admin Control Center</h1>
      <p class="font-body-md text-body-md text-on-surface-variant">Manage users, analyses, and system settings</p>
    </div>
    <div class="flex gap-sm flex-wrap">
      <a href="/admin/users" class="px-md py-sm bg-primary/10 border border-primary/30 rounded-lg hover:bg-primary/20 transition-all font-body-md text-primary font-bold flex items-center gap-xs">
        <span class="material-symbols-outlined text-[18px]">group</span> Users
      </a>
      <a href="/admin/analyses" class="px-md py-sm bg-secondary/10 border border-secondary/30 rounded-lg hover:bg-secondary/20 transition-all font-body-md text-secondary font-bold flex items-center gap-xs">
        <span class="material-symbols-outlined text-[18px]">analytics</span> Analyses
      </a>
      <a href="/admin/logs" class="px-md py-sm bg-tertiary/10 border border-tertiary/30 rounded-lg hover:bg-tertiary/20 transition-all font-body-md text-tertiary font-bold flex items-center gap-xs">
        <span class="material-symbols-outlined text-[18px]">history</span> Logs
      </a>
      <a href="/admin/settings" class="px-md py-sm bg-on-surface-variant/10 border border-on-surface-variant/30 rounded-lg hover:bg-on-surface-variant/20 transition-all font-body-md text-on-surface-variant font-bold flex items-center gap-xs">
        <span class="material-symbols-outlined text-[18px]">settings</span> Settings
      </a>
    </div>
  </div>

  <!-- KPI Cards - Enhanced -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-md mb-xl">
    <!-- Total Users Card -->
    <div class="glass-card p-lg rounded-xl group hover:border-primary/50 transition-all">
      <div class="flex items-center justify-between mb-md">
        <span class="w-10 h-10 rounded-lg bg-primary/20 flex items-center justify-center group-hover:bg-primary/30 transition-colors">
          <span class="material-symbols-outlined text-primary text-[20px]">people</span>
        </span>
        <span class="text-xs font-bold px-xs py-1 rounded-full bg-primary/20 text-primary">Users</span>
      </div>
      <p class="font-body-sm text-body-md text-on-surface-variant mb-xs">Total Users</p>
      <p class="font-display-xl text-4xl text-primary font-bold"><%= stats.users.total %></p>
      <div class="flex items-center gap-xs mt-md">
        <span class="text-xs text-on-surface-variant">Verified:</span>
        <span class="text-sm font-bold text-primary"><%= stats.users.verified || 0 %></span>
      </div>
    </div>

    <!-- Active Analyses Card -->
    <div class="glass-card p-lg rounded-xl group hover:border-secondary/50 transition-all">
      <div class="flex items-center justify-between mb-md">
        <span class="w-10 h-10 rounded-lg bg-secondary/20 flex items-center justify-center group-hover:bg-secondary/30 transition-colors">
          <span class="material-symbols-outlined text-secondary text-[20px]">image_search</span>
        </span>
        <span class="text-xs font-bold px-xs py-1 rounded-full bg-secondary/20 text-secondary">Activity</span>
      </div>
      <p class="font-body-sm text-body-md text-on-surface-variant mb-xs">Active Analyses</p>
      <p class="font-display-xl text-4xl text-secondary font-bold"><%= stats.analyses.processing || 0 %></p>
      <div class="flex items-center gap-xs mt-md">
        <span class="text-xs text-on-surface-variant">Completed:</span>
        <span class="text-sm font-bold text-secondary"><%= stats.analyses.completed || 0 %></span>
      </div>
    </div>

    <!-- Total Analyses Card -->
    <div class="glass-card p-lg rounded-xl group hover:border-tertiary/50 transition-all">
      <div class="flex items-center justify-between mb-md">
        <span class="w-10 h-10 rounded-lg bg-tertiary/20 flex items-center justify-center group-hover:bg-tertiary/30 transition-colors">
          <span class="material-symbols-outlined text-tertiary text-[20px]">description</span>
        </span>
        <span class="text-xs font-bold px-xs py-1 rounded-full bg-tertiary/20 text-tertiary">Total</span>
      </div>
      <p class="font-body-sm text-body-md text-on-surface-variant mb-xs">Total Analyses</p>
      <p class="font-display-xl text-4xl text-tertiary font-bold"><%= stats.analyses.total %></p>
      <div class="flex items-center gap-xs mt-md">
        <span class="text-xs text-on-surface-variant">Uploads:</span>
        <span class="text-sm font-bold text-tertiary"><%= stats.uploads.total %></span>
      </div>
    </div>

    <!-- Storage Card -->
    <div class="glass-card p-lg rounded-xl group hover:border-primary/50 transition-all">
      <div class="flex items-center justify-between mb-md">
        <span class="w-10 h-10 rounded-lg bg-primary/20 flex items-center justify-center group-hover:bg-primary/30 transition-colors">
          <span class="material-symbols-outlined text-primary text-[20px]">storage</span>
        </span>
        <span class="text-xs font-bold px-xs py-1 rounded-full bg-primary/20 text-primary">Storage</span>
      </div>
      <p class="font-body-sm text-body-md text-on-surface-variant mb-xs">Total Storage</p>
      <p class="font-display-xl text-4xl text-primary font-bold"><%= ((stats.uploads.total_size || 0) / (1024 * 1024)).toFixed(2) %><span class="text-lg">MB</span></p>
      <div class="flex items-center gap-xs mt-md">
        <span class="w-full h-1 rounded-full bg-surface-container-high overflow-hidden">
          <div class="h-full bg-gradient-to-r from-primary to-secondary" style="width: 65%;"></div>
        </span>
      </div>
    </div>
  </div>

  <!-- Main Content Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-lg mb-xl">
    <!-- Recent Users -->
    <div class="lg:col-span-2">
      <div class="glass-card rounded-xl overflow-hidden">
        <div class="p-lg border-b border-white/10 flex items-center justify-between">
          <div>
            <h2 class="font-headline-sm text-headline-sm mb-xs">Recent Users</h2>
            <p class="font-body-sm text-body-sm text-on-surface-variant">Latest registrations</p>
          </div>
          <a href="/admin/users" class="text-primary font-body-sm font-bold hover:text-secondary transition-colors flex items-center gap-xs">
            View All <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
          </a>
        </div>
        <div class="divide-y divide-white/5 max-h-96 overflow-y-auto">
          <% (recentUsers || []).forEach((u, idx) => { %>
            <div class="p-md hover:bg-white/5 transition-colors flex items-center justify-between">
              <div class="flex items-center gap-md flex-1">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary/30 to-secondary/30 flex items-center justify-center text-primary font-bold text-sm shrink-0">
                  <%= u.name.charAt(0).toUpperCase() %>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="font-body-md text-body-md text-on-surface font-bold truncate"><%= u.name %></p>
                  <p class="font-label-sm text-label-sm text-on-surface-variant truncate"><%= u.email %></p>
                </div>
              </div>
              <div class="text-right shrink-0">
                <p class="font-label-sm text-label-sm text-on-surface-variant"><%= new Date(u.created_at).toLocaleDateString() %></p>
                <a href="/admin/users" class="text-primary hover:text-secondary transition-colors font-label-sm font-bold">Details</a>
              </div>
            </div>
          <% }) %>
          <% if (!recentUsers || recentUsers.length === 0) { %>
            <div class="p-lg text-center text-on-surface-variant">
              <p class="font-body-md">No users yet</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- System Status -->
    <div class="space-y-lg">
      <!-- System Health -->
      <div class="glass-card rounded-xl p-lg">
        <h3 class="font-headline-sm text-headline-sm mb-md">System Health</h3>
        <div class="space-y-md">
          <div>
            <div class="flex items-center justify-between mb-xs">
              <span class="font-body-sm text-body-sm text-on-surface">Database</span>
              <span class="text-xs font-bold px-xs py-1 rounded-full bg-primary/20 text-primary">Connected</span>
            </div>
            <div class="w-full h-1 rounded-full bg-surface-container-high overflow-hidden">
              <div class="h-full bg-primary w-full"></div>
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-xs">
              <span class="font-body-sm text-body-sm text-on-surface">API</span>
              <span class="text-xs font-bold px-xs py-1 rounded-full bg-secondary/20 text-secondary">Operational</span>
            </div>
            <div class="w-full h-1 rounded-full bg-surface-container-high overflow-hidden">
              <div class="h-full bg-secondary w-full"></div>
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-xs">
              <span class="font-body-sm text-body-sm text-on-surface">Storage</span>
              <span class="text-xs font-bold px-xs py-1 rounded-full bg-tertiary/20 text-tertiary">65% Used</span>
            </div>
            <div class="w-full h-1 rounded-full bg-surface-container-high overflow-hidden">
              <div class="h-full bg-tertiary" style="width: 65%;"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick Stats -->
      <div class="glass-card rounded-xl p-lg">
        <h3 class="font-headline-sm text-headline-sm mb-md">Quick Stats</h3>
        <div class="space-y-sm">
          <div class="flex items-center justify-between p-md rounded-lg bg-primary/5 border border-primary/10">
            <span class="font-body-sm text-body-sm text-on-surface">Avg Confidence Score</span>
            <span class="text-lg font-bold text-primary">94%</span>
          </div>
          <div class="flex items-center justify-between p-md rounded-lg bg-secondary/5 border border-secondary/10">
            <span class="font-body-sm text-body-sm text-on-surface">Avg Processing Time</span>
            <span class="text-lg font-bold text-secondary">2.3s</span>
          </div>
          <div class="flex items-center justify-between p-md rounded-lg bg-tertiary/5 border border-tertiary/10">
            <span class="font-body-sm text-body-sm text-on-surface">Active Sessions</span>
            <span class="text-lg font-bold text-tertiary"><%= stats.users.total %></span>
          </div>
          <div class="flex items-center justify-between p-md rounded-lg bg-on-surface-variant/5 border border-on-surface-variant/10">
            <span class="font-body-sm text-body-sm text-on-surface">Success Rate</span>
            <span class="text-lg font-bold text-on-surface-variant">99.2%</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Recent Analyses Table -->
  <div class="glass-card rounded-xl overflow-hidden">
    <div class="p-lg border-b border-white/10 flex items-center justify-between">
      <div>
        <h2 class="font-headline-sm text-headline-sm mb-xs">Recent Analyses</h2>
        <p class="font-body-sm text-body-sm text-on-surface-variant">Latest design submissions</p>
      </div>
      <a href="/admin/analyses" class="text-primary font-body-sm font-bold hover:text-secondary transition-colors flex items-center gap-xs">
        View All <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
      </a>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b border-white/5 bg-surface-container-high/50">
            <th class="px-lg py-md text-left font-body-md text-on-surface-variant text-xs font-bold uppercase tracking-wider">Title</th>
            <th class="px-lg py-md text-left font-body-md text-on-surface-variant text-xs font-bold uppercase tracking-wider">User</th>
            <th class="px-lg py-md text-center font-body-md text-on-surface-variant text-xs font-bold uppercase tracking-wider">Status</th>
            <th class="px-lg py-md text-center font-body-md text-on-surface-variant text-xs font-bold uppercase tracking-wider">Confidence</th>
            <th class="px-lg py-md text-right font-body-md text-on-surface-variant text-xs font-bold uppercase tracking-wider">Date</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
          <% (recentAnalyses || []).forEach(a => { %>
            <tr class="hover:bg-white/5 transition-colors">
              <td class="px-lg py-md">
                <p class="font-body-md text-body-md text-on-surface font-bold truncate"><%= a.title || 'Untitled' %></p>
              </td>
              <td class="px-lg py-md">
                <p class="font-body-sm text-body-sm text-on-surface-variant"><%= a.user_name %></p>
              </td>
              <td class="px-lg py-md text-center">
                <span class="px-sm py-xs rounded-full text-xs font-bold inline-block <%= a.status === 'completed' ? 'bg-primary/20 text-primary' : a.status === 'processing' ? 'bg-secondary/20 text-secondary' : a.status === 'failed' ? 'bg-error/20 text-error' : 'bg-on-surface-variant/20 text-on-surface-variant' %>">
                  <span class="inline-block w-2 h-2 rounded-full mr-1 <%= a.status === 'completed' ? 'bg-primary' : a.status === 'processing' ? 'bg-secondary animate-pulse' : a.status === 'failed' ? 'bg-error' : 'bg-on-surface-variant' %>" style="display: inline-block;"></span>
                  <%= a.status %>
                </span>
              </td>
              <td class="px-lg py-md text-center">
                <p class="font-label-sm text-label-sm text-on-surface-variant"><%= a.confidence_score ? a.confidence_score + '%' : '—' %></p>
              </td>
              <td class="px-lg py-md text-right">
                <p class="font-label-sm text-label-sm text-on-surface-variant"><%= new Date(a.created_at).toLocaleDateString() %></p>
              </td>
            </tr>
          <% }) %>
          <% if (!recentAnalyses || recentAnalyses.length === 0) { %>
            <tr>
              <td colspan="5" class="px-lg py-lg text-center text-on-surface-variant">
                <p class="font-body-md">No analyses yet</p>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script src="/js/admin-dashboard.js"></script>

<%- include('../partials/footer') %>
