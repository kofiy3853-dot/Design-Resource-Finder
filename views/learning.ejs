<%- include('partials/header') %>
<div class="pt-24 pb-xl max-w-container-max mx-auto px-md">
<div class="flex items-center gap-sm mb-lg reveal">
  <a href="/dashboard" class="text-on-surface-variant hover:text-primary transition-colors flex items-center gap-xs font-body-md">
    <span class="material-symbols-outlined">arrow_back</span> Back to Dashboard
  </a>
  <h1 class="font-headline-lg text-headline-lg mb-sm">Learning Center</h1>
  <p class="font-body-md text-body-md text-on-surface-variant max-w-xl mx-auto">Master the fundamentals of design through AI-powered lessons</p>
</div>
<% if (lessons && lessons.length > 0) { %>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-lg">
<% lessons.forEach(lesson => { %>
<div class="glass-card p-lg rounded-xl reveal">
<div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-md">
<span class="material-symbols-outlined text-primary">menu_book</span>
</div>
<h3 class="font-headline-sm text-headline-sm mb-sm"><%= lesson.title %></h3>
<p class="font-label-sm text-label-sm text-primary uppercase mb-md"><%= lesson.category %></p>
<p class="font-body-md text-body-md text-on-surface-variant mb-md"><%= lesson.content.substring(0, 120) %>...</p>
<a href="#" class="text-primary hover:underline font-body-md">Read more →</a>
</div>
<% }) %>
</div>
<% } else { %>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-lg">
<div class="glass-card p-lg rounded-xl reveal">
<div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-md">
<span class="material-symbols-outlined text-primary">format_size</span>
</div>
<h3 class="font-headline-sm text-headline-sm mb-sm">Typography Fundamentals</h3>
<p class="font-label-sm text-label-sm text-primary uppercase mb-md">Typography</p>
<p class="font-body-md text-body-md text-on-surface-variant">Learn how typefaces, font pairing, hierarchy, and spacing create readable and beautiful designs.</p>
</div>
<div class="glass-card p-lg rounded-xl reveal" style="transition-delay: 0.1s;">
<div class="w-12 h-12 rounded-lg bg-secondary/10 flex items-center justify-center mb-md">
<span class="material-symbols-outlined text-secondary">palette</span>
</div>
<h3 class="font-headline-sm text-headline-sm mb-sm">Color Theory</h3>
<p class="font-label-sm text-label-sm text-secondary uppercase mb-md">Color</p>
<p class="font-body-md text-body-md text-on-surface-variant">Understand color harmony, contrast, psychology, and how to build accessible color palettes.</p>
</div>
<div class="glass-card p-lg rounded-xl reveal" style="transition-delay: 0.2s;">
<div class="w-12 h-12 rounded-lg bg-tertiary/10 flex items-center justify-center mb-md">
<span class="material-symbols-outlined text-tertiary">grid_view</span>
</div>
<h3 class="font-headline-sm text-headline-sm mb-sm">Composition & Layout</h3>
<p class="font-label-sm text-label-sm text-tertiary uppercase mb-md">Layout</p>
<p class="font-body-md text-body-md text-on-surface-variant">Master grid systems, visual hierarchy, white space, and balance in your designs.</p>
</div>
</div>
<% } %>
</div>
<%- include('partials/footer') %>
