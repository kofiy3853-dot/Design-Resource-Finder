<%- include('partials/header') %>
<main class="pt-24 pb-xl">
  <div class="max-w-container-max mx-auto px-md">
    <div class="flex items-center gap-sm mb-lg">
      <a href="/dashboard" class="text-on-surface-variant hover:text-primary transition-colors flex items-center gap-xs font-body-md">
        <span class="material-symbols-outlined">arrow_back</span> Back to Dashboard
      </a>
      <h1 class="font-headline-lg text-headline-lg mb-sm">Projects</h1>
      <p class="font-body-md text-body-md text-on-surface-variant">Organize your analyses into projects</p>
    </div>

    <div class="glass-card rounded-2xl p-xl text-center">
      <span class="material-symbols-outlined text-5xl text-on-surface-variant/30 mb-md" style="font-variation-settings:'FILL'1;">folder_open</span>
      <h2 class="font-headline-sm text-headline-sm mb-sm">No projects yet</h2>
      <p class="font-body-md text-body-md text-on-surface-variant mb-lg">Create a project to organize your design analyses</p>
      <button class="px-lg py-sm bg-primary text-on-primary rounded-xl font-bold">Create Project</button>
    </div>
  </div>
</main>
<%- include('partials/footer') %>