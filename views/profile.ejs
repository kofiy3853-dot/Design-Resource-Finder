<%- include('partials/header-app') %>
<%- include('partials/dashboard-layout') %>

<div class="dash-page-header">
  <h1>Profile</h1>
  <p>Your account information</p>
</div>

<div style="max-width:640px">
  <div class="dash-card" style="text-align:center;margin-bottom:16px">
    <div style="width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--secondary));display:flex;align-items:center;justify-content:center;margin:0 auto 16px">
      <span style="font-size:32px;font-weight:700;color:#fff"><%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %></span>
    </div>
    <h2 style="font-size:20px;font-weight:600;color:var(--on-surface);margin-bottom:4px"><%= user.name %></h2>
    <p style="font-size:14px;color:var(--text-secondary)"><%= user.email %></p>
    <p style="font-size:12px;color:var(--text-muted);margin-top:4px">Joined <%= new Date(user.created_at).toLocaleDateString() %></p>
  </div>

  <div class="dash-card" style="margin-bottom:16px">
    <h3 style="font-size:16px;font-weight:600;color:var(--on-surface);margin-bottom:16px">Account Information</h3>
    <div style="display:flex;flex-direction:column;gap:16px">
      <div>
        <label style="font-size:12px;color:var(--text-muted);display:block;margin-bottom:4px">Full Name</label>
        <p style="font-size:14px;color:var(--on-surface)"><%= user.name %></p>
      </div>
      <div>
        <label style="font-size:12px;color:var(--text-muted);display:block;margin-bottom:4px">Email</label>
        <p style="font-size:14px;color:var(--on-surface)"><%= user.email %></p>
      </div>
      <div>
        <label style="font-size:12px;color:var(--text-muted);display:block;margin-bottom:4px">Role</label>
        <p style="font-size:14px;color:var(--primary);text-transform:capitalize"><%= user.role %></p>
      </div>
    </div>
  </div>

  <a href="/settings" class="dash-btn-secondary" style="width:100%;justify-content:center">
    Edit Settings
  </a>
</div>

<%- include('partials/dashboard-footer') %>
