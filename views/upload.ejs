<%- include('partials/header-app') %>
<div class="dash-page">
  <div class="dash-sidebar-overlay" id="sidebarOverlay"></div>

  <div class="dash-layout">
    <aside class="dash-sidebar" id="sidebar">
      <div class="dash-sidebar-header">
        <div class="dash-sidebar-logo"><span class="material-symbols-outlined">auto_awesome</span></div>
        <div class="dash-sidebar-brand">
          <h3>Design Resource Finder</h3>
          <p>Dashboard</p>
        </div>
      </div>
      <nav class="dash-sidebar-nav">
        <ul>
          <li class="dash-nav-label">Main</li>
          <li><a class="dash-nav-item" href="/dashboard"><span class="material-symbols-outlined">dashboard</span> Dashboard</a></li>
          <li><a class="dash-nav-item active" href="/upload"><span class="material-symbols-outlined">upload_file</span> Upload Design</a></li>
          <li><a class="dash-nav-item" href="/history"><span class="material-symbols-outlined">history</span> History</a></li>
          <li><a class="dash-nav-item" href="/projects"><span class="material-symbols-outlined">folder</span> Projects</a></li>
          <li><a class="dash-nav-item" href="/favorites"><span class="material-symbols-outlined">favorite</span> Favorites</a></li>
          <li><a class="dash-nav-item" href="/bg-generator"><span class="material-symbols-outlined">auto_fix_high</span> AI Background Generator</a></li>
          <li class="dash-nav-label">Resources</li>
          <li><a class="dash-nav-item" href="/resources"><span class="material-symbols-outlined">grid_view</span> Resources</a></li>
          <li><a class="dash-nav-item" href="/pricing"><span class="material-symbols-outlined">sell</span> Pricing</a></li>
          <li><a class="dash-nav-item" href="/settings"><span class="material-symbols-outlined">settings</span> Settings</a></li>
          <li><a class="dash-nav-item" href="/help"><span class="material-symbols-outlined">help</span> Help & Support</a></li>
        </ul>
      </nav>
      <div class="dash-sidebar-footer">
        <div class="dash-upgrade-card">
          <h4>Upgrade to Pro</h4>
          <p>Unlock unlimited analyses</p>
          <a href="/pricing" class="dash-upgrade-btn dash-ripple">Upgrade Now</a>
        </div>
        <div class="dash-user-card">
          <div class="dash-avatar"><%= user?.name ? user.name.charAt(0).toUpperCase() : 'U' %></div>
          <div class="dash-user-info">
            <h4><%= user?.name || 'User' %></h4>
            <p><%= user?.email || 'user@example.com' %></p>
          </div>
          <span class="material-symbols-outlined dash-user-toggle" id="userMenuToggle">expand_more</span>
          <div class="dash-user-dropdown" id="userDropdown">
            <a href="/profile">Profile</a>
            <a href="/settings">Settings</a>
            <a href="/achievements">Achievements</a>
            <a href="/auth/logout" class="dash-logout">Sign Out</a>
          </div>
        </div>
      </div>
    </aside>

    <main class="dash-main">
      <div class="dash-content">
        <div class="dash-page-header">
          <a href="/dashboard" class="flex items-center gap-xs font-body-md"><span class="material-symbols-outlined">arrow_back</span> Back to Dashboard</a>
          <h1>Analyze Your Design</h1>
          <p>Upload a flyer, poster, logo, social media post, or website screenshot and let AI identify the fonts, colors, layout, typography, and design style.</p>
        </div>

        <div class="dash-grid-2">
          <div>
            <!-- Upload State -->
            <div id="uploadState">
              <div class="dash-card" style="margin-bottom:16px">
                <div id="dropZone" style="border:2px dashed var(--nav-border);border-radius:16px;padding:40px 20px;text-align:center;cursor:pointer;transition:all 0.2s" onmouseover="this.style.borderColor='var(--primary)'" onmouseout="this.style.borderColor='var(--nav-border)'">
                  <div style="width:80px;height:80px;border-radius:16px;background:rgba(124,58,237,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 16px">
                    <span class="material-symbols-outlined" style="font-size:40px;color:var(--primary);opacity:0.6">cloud_upload</span>
                  </div>
                  <p style="font-size:16px;font-weight:600;color:var(--on-surface);margin-bottom:4px">Drag & drop your design here</p>
                  <p style="font-size:14px;color:var(--text-secondary);margin-bottom:12px">or <span style="color:var(--primary);font-weight:600">browse files</span></p>
                  <p style="font-size:12px;color:var(--text-muted)">PNG, JPG, WEBP, SVG, PDF — Max 10 MB</p>
                  <div style="display:flex;gap:8px;justify-content:center;margin-top:12px">
                    <span style="padding:4px 10px;border-radius:12px;background:rgba(124,58,237,0.1);color:var(--primary);font-size:11px;font-weight:600">PNG</span>
                    <span style="padding:4px 10px;border-radius:12px;background:rgba(197,189,255,0.1);color:var(--secondary);font-size:11px;font-weight:600">JPG</span>
                    <span style="padding:4px 10px;border-radius:12px;background:rgba(195,199,205,0.1);color:var(--tertiary);font-size:11px;font-weight:600">WEBP</span>
                    <span style="padding:4px 10px;border-radius:12px;background:rgba(124,58,237,0.1);color:var(--primary);font-size:11px;font-weight:600">SVG</span>
                    <span style="padding:4px 10px;border-radius:12px;background:rgba(197,189,255,0.1);color:var(--secondary);font-size:11px;font-weight:600">PDF</span>
                  </div>
                </div>
                <input id="fileInput" type="file" accept="image/*,.pdf" style="display:none"/>
              </div>

              <div style="display:flex;gap:12px">
                <button id="pasteBtn" class="dash-btn-secondary" style="flex:1">
                  <span class="material-symbols-outlined" style="font-size:18px">content_paste</span> Paste Image
                </button>
              </div>
            </div>

            <!-- Preview State -->
            <div id="previewState" style="display:none">
              <div class="dash-card" style="margin-bottom:16px">
                <div style="position:relative;background:var(--surface-container-high);border-radius:12px;overflow:hidden;min-height:200px;display:flex;align-items:center;justify-content:center;margin-bottom:16px">
                  <img id="previewImage" style="max-width:100%;max-height:300px;object-fit:contain"/>
                  <button id="removeFile" style="position:absolute;top:12px;right:12px;width:32px;height:32px;border-radius:50%;background:rgba(0,0,0,0.5);color:#fff;display:flex;align-items:center;justify-content:center;border:none;cursor:pointer">
                    <span class="material-symbols-outlined" style="font-size:18px">close</span>
                  </button>
                </div>
                <div style="display:flex;align-items:center;gap:12px">
                  <div style="width:40px;height:40px;border-radius:8px;background:rgba(124,58,237,0.1);display:flex;align-items:center;justify-content:center">
                    <span class="material-symbols-outlined" style="color:var(--primary);font-size:20px">description</span>
                  </div>
                  <div style="flex:1;min-width:0">
                    <p id="fileName" style="font-size:14px;font-weight:600;color:var(--on-surface);white-space:nowrap;overflow:hidden;text-overflow:ellipsis"></p>
                    <div style="display:flex;gap:12px;font-size:12px;color:var(--text-muted)">
                      <span id="fileSize"></span>
                      <span id="fileDims"></span>
                    </div>
                  </div>
                  <button id="replaceFile" class="dash-btn-secondary" style="padding:6px 12px">
                    <span class="material-symbols-outlined" style="font-size:16px">refresh</span> Replace
                  </button>
                </div>
              </div>

              <button id="analyzeBtn" class="dash-btn-primary dash-ripple" style="padding:16px">
                <span class="material-symbols-outlined">auto_awesome</span> Analyze Design
              </button>
            </div>

            <!-- Processing State -->
            <div id="processingState" style="display:none">
              <div class="dash-card" style="text-align:center">
                <div style="width:64px;height:64px;border-radius:16px;background:rgba(124,58,237,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 16px">
                  <span class="material-symbols-outlined" style="font-size:32px;color:var(--primary);animation:spin 1s linear infinite">progress_activity</span>
                </div>
                <h2 style="font-size:18px;font-weight:600;color:var(--on-surface);margin-bottom:8px">AI is Analyzing Your Design</h2>
                <p style="font-size:14px;color:var(--text-secondary);margin-bottom:24px">Please wait while our AI processes your design.</p>

                <div style="width:100%;height:4px;background:rgba(255,255,255,0.05);border-radius:4px;overflow:hidden;margin-bottom:24px">
                  <div id="progressBarFull" style="height:100%;background:linear-gradient(90deg,var(--primary),var(--secondary));border-radius:4px;transition:width 0.3s;width:0%"></div>
                </div>

                <div id="progressSteps" style="max-width:300px;margin:0 auto;text-align:left">
                  <div class="progress-step done" data-step="upload">
                    <span class="material-symbols-outlined" style="color:var(--primary);font-size:18px">check_circle</span>
                    <span style="font-size:13px;color:var(--on-surface)">Upload Complete</span>
                  </div>
                  <div class="progress-step active" data-step="colors">
                    <span class="material-symbols-outlined" style="color:var(--text-muted);font-size:18px">palette</span>
                    <span style="font-size:13px;color:var(--text-secondary)">Extracting Colors</span>
                  </div>
                  <div class="progress-step" data-step="ai">
                    <span class="material-symbols-outlined" style="color:var(--text-muted);font-size:18px">auto_awesome</span>
                    <span style="font-size:13px;color:var(--text-secondary)">AI Analysis</span>
                  </div>
                  <div class="progress-step" data-step="report">
                    <span class="material-symbols-outlined" style="color:var(--text-muted);font-size:18px">description</span>
                    <span style="font-size:13px;color:var(--text-secondary)">Preparing Report</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Error State -->
            <div id="errorState" style="display:none">
              <div class="dash-card" style="text-align:center;border-color:rgba(239,68,68,0.3)">
                <span class="material-symbols-outlined" style="font-size:56px;color:var(--error);opacity:0.5;margin-bottom:16px;display:block">error_outline</span>
                <h2 style="font-size:18px;font-weight:600;color:var(--on-surface);margin-bottom:8px" id="errorTitle">Upload Failed</h2>
                <p style="font-size:14px;color:var(--text-secondary);margin-bottom:24px" id="errorMessage">Something went wrong. Please try again.</p>
                <button onclick="resetAll()" class="dash-btn-secondary">Try Again</button>
              </div>
            </div>
          </div>

          <div>
            <!-- Tips Card -->
            <div class="dash-card" style="margin-bottom:16px">
              <h3 style="font-size:16px;font-weight:600;color:var(--on-surface);margin-bottom:16px;display:flex;align-items:center;gap:8px">
                <span class="material-symbols-outlined" style="color:var(--primary)">tips_and_updates</span> Tips for Best Results
              </h3>
              <ul style="list-style:none;padding:0;margin:0">
                <li style="display:flex;align-items:flex-start;gap:8px;margin-bottom:12px">
                  <span class="material-symbols-outlined" style="color:var(--primary);font-size:18px;margin-top:2px">check_small</span>
                  <span style="font-size:13px;color:var(--text-secondary)">Upload high-resolution images for the most accurate analysis.</span>
                </li>
                <li style="display:flex;align-items:flex-start;gap:8px;margin-bottom:12px">
                  <span class="material-symbols-outlined" style="color:var(--primary);font-size:18px;margin-top:2px">check_small</span>
                  <span style="font-size:13px;color:var(--text-secondary)">Avoid blurry or heavily cropped designs — clarity improves detection.</span>
                </li>
                <li style="display:flex;align-items:flex-start;gap:8px;margin-bottom:12px">
                  <span class="material-symbols-outlined" style="color:var(--primary);font-size:18px;margin-top:2px">check_small</span>
                  <span style="font-size:13px;color:var(--text-secondary)">Include the full design where possible for complete analysis.</span>
                </li>
                <li style="display:flex;align-items:flex-start;gap:8px">
                  <span class="material-symbols-outlined" style="color:var(--primary);font-size:18px;margin-top:2px">check_small</span>
                  <span style="font-size:13px;color:var(--text-secondary)">PNG and PDF formats typically provide the best results.</span>
                </li>
              </ul>
            </div>

            <!-- Recent Uploads -->
            <% if (typeof recentAnalyses !== 'undefined' && recentAnalyses && recentAnalyses.length > 0) { %>
            <div class="dash-card">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
                <h3 style="font-size:16px;font-weight:600;color:var(--on-surface);display:flex;align-items:center;gap:8px">
                  <span class="material-symbols-outlined" style="color:var(--primary)">history</span> Recent Uploads
                </h3>
                <a href="/history" style="font-size:13px;color:var(--primary);text-decoration:none">View all</a>
              </div>
              <div style="display:flex;flex-direction:column;gap:8px">
                <% recentAnalyses.slice(0, 3).forEach(function(a) { %>
                <a href="/analysis/<%= a.id %>" style="display:flex;align-items:center;gap:12px;padding:12px;border-radius:12px;background:var(--surface-container-high);text-decoration:none;transition:all 0.2s" onmouseover="this.style.background='rgba(255,255,255,0.05)'" onmouseout="this.style.background='var(--surface-container-high)'">
                  <div style="width:40px;height:40px;border-radius:8px;background:rgba(124,58,237,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                    <span class="material-symbols-outlined" style="color:var(--primary);font-size:18px">image</span>
                  </div>
                  <div style="flex:1;min-width:0">
                    <p style="font-size:13px;font-weight:600;color:var(--on-surface);white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= a.title || 'Untitled' %></p>
                    <p style="font-size:11px;color:var(--text-muted)"><%= new Date(a.created_at).toLocaleDateString() %></p>
                  </div>
                  <span style="padding:2px 8px;border-radius:12px;font-size:10px;font-weight:700;background:<%= a.status === 'completed' ? 'rgba(124,58,237,0.2)' : 'rgba(197,189,255,0.2)' %>;color:<%= a.status === 'completed' ? 'var(--primary)' : 'var(--secondary)' %>"><%= a.status %></span>
                </a>
                <% }) %>
              </div>
            </div>
            <% } else { %>
            <div class="dash-card" style="text-align:center">
              <span class="material-symbols-outlined" style="font-size:48px;color:var(--text-muted);opacity:0.2;margin-bottom:12px;display:block">insights</span>
              <p style="font-size:14px;color:var(--text-secondary)">No designs uploaded yet</p>
              <p style="font-size:12px;color:var(--text-muted);margin-top:4px">Upload your first design to begin</p>
            </div>
            <% } %>
          </div>
        </div>
      </div>
    </main>
  </div>

  <div class="dash-toast-container" id="toastContainer"></div>
</div>

<style>
  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

  .progress-step {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 8px;
    margin-bottom: 4px;
    transition: all 0.2s;
  }
  .progress-step.done {
    background: rgba(124,58,237,0.05);
  }
  .progress-step.active {
    background: rgba(124,58,237,0.1);
  }
  .progress-step.active span:first-child {
    color: var(--primary) !important;
    animation: pulse 1s infinite;
  }
  .progress-step.done span:first-child {
    color: var(--primary) !important;
  }
  @keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.4; } }
</style>

<script src="/js/dashboard-v2.js"></script>
<script>
let selectedFile = null;
let isProcessing = false;
let currentAnalysisId = null;

const dropZone = document.getElementById('dropZone');
const fileInput = document.getElementById('fileInput');
const previewState = document.getElementById('previewState');
const uploadState = document.getElementById('uploadState');
const processingState = document.getElementById('processingState');
const errorState = document.getElementById('errorState');
const previewImage = document.getElementById('previewImage');
const fileName = document.getElementById('fileName');
const fileSize = document.getElementById('fileSize');
const fileDims = document.getElementById('fileDims');
const removeFile = document.getElementById('removeFile');
const replaceFile = document.getElementById('replaceFile');
const analyzeBtn = document.getElementById('analyzeBtn');
const progressBarFull = document.getElementById('progressBarFull');

// Drag and drop
dropZone.addEventListener('click', () => fileInput.click());
dropZone.addEventListener('dragover', (e) => {
  e.preventDefault();
  dropZone.style.borderColor = 'var(--primary)';
  dropZone.style.background = 'rgba(124,58,237,0.05)';
});
dropZone.addEventListener('dragleave', () => {
  dropZone.style.borderColor = 'var(--nav-border)';
  dropZone.style.background = 'transparent';
});
dropZone.addEventListener('drop', (e) => {
  e.preventDefault();
  dropZone.style.borderColor = 'var(--nav-border)';
  dropZone.style.background = 'transparent';
  if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
});
fileInput.addEventListener('change', () => {
  if (fileInput.files[0]) handleFile(fileInput.files[0]);
});

// Paste from clipboard
document.getElementById('pasteBtn').addEventListener('click', async () => {
  try {
    const items = await navigator.clipboard.read();
    for (const item of items) {
      for (const type of item.types) {
        if (type.startsWith('image/')) {
          const blob = await item.getType(type);
          const file = new File([blob], 'clipboard.png', { type });
          handleFile(file);
          return;
        }
      }
    }
    showToast('No image found in clipboard', 'error');
  } catch (_) {
    showToast('Clipboard access denied', 'error');
  }
});

function handleFile(file) {
  const validTypes = ['image/jpeg', 'image/png', 'image/webp', 'image/svg+xml', 'application/pdf'];
  if (!validTypes.includes(file.type)) {
    showError('Unsupported File Type', 'Please upload a PNG, JPG, WEBP, SVG, or PDF file.');
    return;
  }
  if (file.size > 10 * 1024 * 1024) {
    showError('File Too Large', 'Maximum file size is 10 MB. Please compress and try again.');
    return;
  }
  selectedFile = file;
  fileName.textContent = file.name;
  fileSize.textContent = (file.size / 1024 / 1024).toFixed(2) + ' MB';
  if (file.type.startsWith('image/')) {
    const reader = new FileReader();
    reader.onload = (e) => {
      previewImage.src = e.target.result;
    };
    reader.readAsDataURL(file);
    const img = new Image();
    img.onload = () => {
      fileDims.textContent = img.width + ' × ' + img.height;
    };
    img.src = URL.createObjectURL(file);
  } else {
    previewImage.src = '';
    previewImage.alt = 'PDF Document';
    fileDims.textContent = 'PDF';
  }
  uploadState.style.display = 'none';
  previewState.style.display = 'block';
}

removeFile.addEventListener('click', resetAll);
replaceFile.addEventListener('click', () => fileInput.click());

// Analyze button
analyzeBtn.addEventListener('click', async () => {
  if (!selectedFile || isProcessing) return;
  isProcessing = true;
  previewState.style.display = 'none';
  processingState.style.display = 'block';
  progressBarFull.style.width = '10%';

  const formData = new FormData();
  formData.append('file', selectedFile);

  try {
    const res = await fetch('/upload', { method: 'POST', body: formData });
    const data = await res.json();

    if (res.ok && data.data && data.data.analysisId) {
      currentAnalysisId = data.data.analysisId;
      progressBarFull.style.width = '30%';
      updateStep('upload', 'done');
      updateStep('colors', 'active');
      pollProgress(currentAnalysisId);
    } else {
      showError('Upload Failed', data.error?.message || 'Server error');
    }
  } catch (err) {
    showError('Network Error', 'Could not reach the server. Check your connection and try again.');
  }
});

function pollProgress(analysisId) {
  const pollInterval = setInterval(async () => {
    try {
      const res = await fetch('/api/analysis/' + analysisId + '/progress');
      const data = await res.json();

      if (data.status === 'completed') {
        clearInterval(pollInterval);
        progressBarFull.style.width = '100%';
        updateStep('ai', 'done');
        updateStep('report', 'active');
        setTimeout(() => {
          window.location.href = '/analysis/' + analysisId;
        }, 500);
      } else if (data.status === 'failed') {
        clearInterval(pollInterval);
        showError('Analysis Failed', data.lastError || 'Something went wrong during analysis.');
      } else {
        // Update progress based on current step
        if (data.currentStep) {
          updateProgressFromStep(data.currentStep, data.progress || 0);
        }
      }
    } catch (err) {
      console.error('Progress poll error:', err);
    }
  }, 1500);
}

function updateProgressFromStep(step, progress) {
  const stepProgress = {
    'color_analysis': 40,
    'ai_analysis': 60,
    'saving_results': 80,
    'completed': 100
  };
  const baseProgress = stepProgress[step] || 50;
  progressBarFull.style.width = Math.min(baseProgress + progress * 0.2, 90) + '%';

  if (step === 'color_analysis') {
    updateStep('colors', 'active');
  } else if (step === 'ai_analysis') {
    updateStep('colors', 'done');
    updateStep('ai', 'active');
  } else if (step === 'saving_results') {
    updateStep('ai', 'done');
    updateStep('report', 'active');
  }
}

function updateStep(stepName, state) {
  const step = document.querySelector('[data-step="' + stepName + '"]');
  if (!step) return;

  step.classList.remove('done', 'active');
  if (state === 'done') {
    step.classList.add('done');
    step.querySelector('span:first-child').textContent = 'check_circle';
  } else if (state === 'active') {
    step.classList.add('active');
    step.querySelector('span:first-child').textContent = stepName === 'upload' ? 'check_circle' :
      stepName === 'colors' ? 'palette' :
      stepName === 'ai' ? 'auto_awesome' : 'description';
  }
}

function showError(title, msg) {
  isProcessing = false;
  processingState.style.display = 'none';
  errorState.style.display = 'block';
  document.getElementById('errorTitle').textContent = title;
  document.getElementById('errorMessage').textContent = msg;
}

function resetAll() {
  selectedFile = null;
  isProcessing = false;
  currentAnalysisId = null;
  errorState.style.display = 'none';
  processingState.style.display = 'none';
  previewState.style.display = 'none';
  uploadState.style.display = 'block';
  progressBarFull.style.width = '0%';

  // Reset steps
  document.querySelectorAll('.progress-step').forEach(step => {
    step.classList.remove('done', 'active');
  });
  const steps = document.querySelectorAll('.progress-step');
  if (steps[0]) steps[0].classList.add('done');
  if (steps[1]) steps[1].classList.add('active');
}

function showToast(msg, type) {
  const container = document.getElementById('toastContainer');
  if (!container) return;
  const toast = document.createElement('div');
  toast.className = 'dash-toast';
  const icon = type === 'error' ? 'error' : 'check_circle';
  const color = type === 'error' ? 'var(--error)' : 'var(--primary)';
  toast.innerHTML = '<span class="material-symbols-outlined" style="color:' + color + ';font-size:18px">' + icon + '</span><span style="font-size:13px;font-weight:500;color:var(--on-surface)">' + msg + '</span>';
  container.appendChild(toast);
  setTimeout(() => {
    toast.style.opacity = '0';
    toast.style.transform = 'translateX(100px)';
    toast.style.transition = 'all 0.3s ease';
    setTimeout(() => toast.remove(), 300);
  }, 3000);
}
</script>
