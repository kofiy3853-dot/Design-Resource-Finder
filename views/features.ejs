.floating-element { animation: float 6s ease-in-out infinite; }
@keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-16px); } }
.floating-delay-1 { animation-delay: 1s; }
.floating-delay-2 { animation-delay: 2s; }
.floating-delay-3 { animation-delay: 3s; }
.particle { position: absolute; width: 4px; height: 4px; background: rgba(179,197,255,0.4); border-radius: 50%; }
.particle:nth-child(1) { top: 10%; left: 10%; animation: float 8s ease-in-out infinite; }
.particle:nth-child(2) { top: 20%; right: 15%; animation: float 7s ease-in-out infinite 1s; }
.particle:nth-child(3) { bottom: 30%; left: 20%; animation: float 9s ease-in-out infinite 2s; }
.particle:nth-child(4) { bottom: 10%; right: 25%; animation: float 6s ease-in-out infinite 0.5s; }
.particle:nth-child(5) { top: 50%; left: 5%; animation: float 10s ease-in-out infinite 1.5s; }
.particle:nth-child(6) { top: 40%; right: 8%; animation: float 7.5s ease-in-out infinite 2.5s; }
.demo-card { opacity: 0; transform: translateX(20px); transition: all 0.6s ease-out; }
.demo-card.active { opacity: 1; transform: translateX(0); }
.category-card { transition: all 0.4s cubic-bezier(0.4,0,0.2,1); }
.category-card:hover { transform: scale(1.02); }
.user-card { transition: all 0.3s ease-out; }
.user-card:hover { transform: translateY(-6px); }
.timeline-step { position: relative; }
.timeline-step::after { content: ''; position: absolute; top: 40px; left: 20px; width: 2px; height: calc(100% - 40px); background: linear-gradient(to bottom, rgba(179,197,255,0.4), transparent); }
.timeline-step:last-child::after { display: none; }
</style>
